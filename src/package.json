{
  "name": "F2F",
  "version": "1.0.0",
  "description": "OneLogin F2F CRI",
  "repository": "https://github.com/alphagov/di-ipv-cri-f2f-api",
  "author": "GDS",
  "license": "MIT",
  "dependencies": {
    "@aws-lambda-powertools/logger": "2.33.1",
    "@aws-lambda-powertools/metrics": "2.33.1",
    "@aws-sdk/client-dynamodb": "3.1045.0",
    "@aws-sdk/client-kms": "3.1045.0",
    "@aws-sdk/client-lambda": "3.1045.0",
    "@aws-sdk/client-s3": "3.1045.0",
    "@aws-sdk/client-sfn": "3.1045.0",
    "@aws-sdk/client-sqs": "3.1045.0",
    "@aws-sdk/client-ssm": "3.1045.0",
    "@aws-sdk/credential-providers": "3.1045.0",
    "@aws-sdk/lib-dynamodb": "3.1045.0",
    "@smithy/node-http-handler": "4.0.4",
    "aws-xray-sdk-core": "3.10.3",
    "axios": "1.16.0",
    "body-parser": "2.2.2",
    "class-validator": "0.14.3",
    "dotenv-cli": "7.4.4",
    "ecdsa-sig-formatter": "1.0.11",
    "esbuild": "0.28.1",
    "jose": "6.2.3",
    "jsonpath": "1.3.0",
    "node-rsa": "1.1.1",
    "notifications-node-client": "7.0.6",
    "pdf-lib": "1.17.1",
    "pdf-merger-js": "5.1.2",
    "pdfkit": "0.16.0"
  },
  "scripts": {
    "unit": "vitest run --coverage tests/unit/",
    "test:unit": "npm run compile && npm run unit",
    "lint:fix": "eslint --fix --output-file ./reports/eslint/report.html --format html -c eslint.config.mjs --ext *.ts .",
    "compile": "./node_modules/.bin/tsc",
    "lint": "eslint -c eslint.config.mjs *.ts .",
    "test:infra": "vitest run --no-color tests/infra",
    "api": "VITEST_JUNIT_OUTPUT_NAME=api-report.xml vitest run --no-file-parallelism --maxWorkers=1 tests/api/backend tests/api/retry",
    "api-pipeline": "VITEST_JUNIT_OUTPUT_NAME=api-report.xml vitest run --no-file-parallelism --maxWorkers=1 tests/api/backend",
    "api-traffic": "VITEST_JUNIT_OUTPUT_NAME=api-report.xml vitest run --no-file-parallelism --maxWorkers=1 tests/api/backend/HappyPath.test.ts tests/api/backend/CallbackApi.test.ts",
    "test:api": "npm run prepare-dependencies && npm run compile && npm run api",
    "test:api-pipeline": "npm run prepare-dependencies && npm run compile && npm run api-pipeline",
    "prepare-dependencies": "npm run prepare-dependencies:canvas",
    "prepare-dependencies:canvas": "cd ./node_modules/canvas && prebuild-install -r napi || node-gyp rebuild",
    "test:api-traffic": "npm run compile && npm run api-traffic",
    "api-third-party": "THIRD_PARTY_CLIENT_ID=SandboxJourneyFlow VITEST_JUNIT_OUTPUT_NAME=third-party-api-report.xml vitest run --no-file-parallelism --maxWorkers=1 tests/api/backend/*Path.test.ts",
    "test:api-third-party": "npm run compile && npm run api-third-party",
    "api-third-party-traffic": "THIRD_PARTY_CLIENT_ID=SandboxJourneyFlow VITEST_JUNIT_OUTPUT_NAME=third-party-api-report.xml vitest run tests/api/backend/HappyPath.test.ts",
    "test:api-third-party-traffic": "npm run compile && npm run api-third-party-traffic",
    "yoti": "VITEST_JUNIT_OUTPUT_NAME=api-report.xml vitest run tests/api/stub/YotiStub.test.ts",
    "test:yoti": "npm run compile && npm run yoti",
    "postoffice": "VITEST_JUNIT_OUTPUT_NAME=api-report.xml vitest run tests/api/stub/PostOfficeStub.test.ts",
    "test:postoffice": "npm run compile && npm run postoffice",
    "govnotify": "VITEST_JUNIT_OUTPUT_NAME=api-report.xml vitest run tests/api/stub/GovNotifyStub.test.ts",
    "test:govnotify": "npm run compile && npm run govnotify",
    "test:pii": "bash ./check-logs.sh",
    "kill:dynamodblocal": "cd tests/contract; ./scripts/kill-dynamodb-local.sh",
    "start:dynamodblocal": "cd tests/contract; ./scripts/setup-dynamodb-local.sh",
    "test:pactconnection": "cd tests/contract; ./scripts/test-pact-connection.sh",
    "start:contract": "npm run start:dynamodblocal && npm run test:pactconnection && npm run wait-start:contract",
    "wait-start:contract": "wait-on tcp:127.0.0.1:8000 && cd tests/contract && tsx ./app.ts",
    "test:provider": "vitest run tests/contract/F2fCriProvider.test.ts",
    "test:contract": "wait-on tcp:127.0.0.1:3000; cd tests/contract; npm run test:provider && npm run kill:dynamodblocal",
    "test:contract:ci": "dotenv -e.env.contract -- bash -c 'npm run start:contract & npm run test:contract && kill $!'",
    "deploy": "cd ../deploy ; sam build && sam deploy --config-env dev --resolve-s3 ; cd src/"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.7",
    "@eslint/compat": "2.0.2",
    "@pact-foundation/pact": "12.1.3",
    "@types/aws-lambda": "8.10.162",
    "@types/express": "4.17.21",
    "@types/js-yaml": "4.0.9",
    "@types/jsonpath": "0.2.4",
    "@types/node": "20.14.8",
    "@types/node-rsa": "1.1.4",
    "@types/pdfkit": "0.13.8",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.1.4",
    "ajv": "8.20.0",
    "aws-cdk-lib": "2.257.0",
    "aws4-axios": "3.4.0",
    "canvas": "3.1.0",
    "dotenv": "16.4.7",
    "eslint": "10.0.2",
    "express": "4.22.2",
    "express-asyncify": "2.1.2",
    "fast-xml-parser": "5.7.3",
    "js-yaml": "4.1.1",
    "pdfjs-dist": "2.16.105",
    "prettier": "3.8.3",
    "typescript": "4.9.5",
    "vitest": "4.1.4",
    "vitest-image-snapshot": "0.6.50",
    "vitest-mock-extended": "4.0.0",
    "wait-on": "9.0.10",
    "yaml-cfn": "0.3.2",
    "tsx": "4.21.0"
  },
  "engines": {
    "node": "24.*"
  },
  "type": "module"
}
