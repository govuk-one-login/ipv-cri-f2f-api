{
  "Comment": "Face to Face CRI - Yoti Callback State Machine",
  "StartAt": "TopicChoiceState",
  "States": {
    "TopicChoiceState": {
      "Type": "Choice",
      "Choices": [
        {
          "Variable": "$.topic",
          "StringEquals": "session_completion",
          "Next": "SessionCompletion"
        },
        {
          "Variable": "$.topic",
          "StringEquals": "thank_you_email_requested",
          "Next": "PostOfficeVisitFunction"
        },
        {
          "Variable": "$.topic",
          "StringEquals": "first_branch_visit",
          "Next": "PostOfficeVisitFunction"
        }
      ]
    },
    "SessionCompletion": {
      "Type": "Task",
      "Resource": "${YotiSessionCompletionFunctionArn}",
      "End": true
    },
    "PostOfficeVisitFunction": {
      "Type": "Task",
      "Resource": "${PostOfficeVisitFunctionArn}",
      "End": true
    }
  }
}
