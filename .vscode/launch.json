    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "name": "Debug Vitest",
            "request": "launch",
            "program": "${workspaceFolder}/src/node_modules/.bin/vitest",
            "args": ["run", "${relativeFile}"],
            "cwd": "${workspaceFolder}/src",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}