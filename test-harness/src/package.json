{
  "name": "test-harness",
  "version": "1.0.0",
  "description": "Harness to enable automation testing",
  "main": "index.js",
  "scripts": {
    "compile": "./node_modules/.bin/tsc",
    "unit": "vitest run tests/unit",
    "test:unit": "npm run compile && npm run unit",
    "lint": "eslint -c eslint.config.mjs *.ts .",
    "lint:fix": "eslint --fix --output-file ./reports/eslint/report.html --format html -c eslint.config.mjs --ext *.ts ."
  },
  "author": "GDS",
  "license": "MIT",
  "dependencies": {
    "@aws-lambda-powertools/logger": "1.5.1",
    "@aws-lambda-powertools/metrics": "1.5.1",
    "@aws-sdk/client-s3": "3.1045.0",
    "@smithy/node-http-handler": "4.0.4",
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.148",
    "@types/node": "20.14.8",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.0.2",
    "typescript": "4.9.4",
    "vitest": "4.1.4",
    "vitest-mock-extended": "3.1.0"
  },
  "engines": {
    "node": "22.*"
  },
  "type": "module"
}
